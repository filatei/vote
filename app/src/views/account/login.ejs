<%- include('../partials/head') %>
<section class="auth-wrap">
  <div class="card narrow auth-card">
    <div class="auth-badge" aria-hidden="true">✉</div>
    <h1 class="auth-title">Sign in to run a vote</h1>
    <p class="lead auth-sub">Enter your email and we'll send a secure sign-in link — no password needed.</p>

    <% if (error) { %><div class="alert alert-error" role="alert"><%= error %></div><% } %>

    <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
      <a class="button button-primary full google-btn" href="/account/auth/google">
        <span class="google-g" aria-hidden="true">G</span> Continue with Google
      </a>
      <div class="auth-or"><span>or use your email</span></div>
    <% } %>

    <form method="post" action="/account/login" class="stack auth-form">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
      <label for="email">Email address</label>
      <input id="email" name="email" type="email" inputmode="email" autocomplete="email"
             placeholder="you@example.com" required autofocus
             pattern="[^@\s]+@[^@\s]+\.[^@\s]+" title="Enter a valid email, e.g. you@example.com" />
      <button class="button button-primary full" type="submit">Email me a sign-in link</button>
    </form>

    <p class="auth-foot">New here? Signing in creates your account automatically.</p>
  </div>
</section>
<%- include('../partials/foot') %>
