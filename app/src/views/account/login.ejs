<%- include('../partials/head') %>
<section class="hero">
  <h1>Sign in to run a vote</h1>
  <p class="lead">Enter your email and we'll send you a secure sign-in link — no password needed.</p>
</section>

<section class="card narrow">
  <% if (error) { %><div class="alert alert-error" role="alert"><%= error %></div><% } %>
  <form method="post" action="/account/login" class="stack" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label for="email">Email address</label>
    <input id="email" name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
    <button class="button button-primary" type="submit">Email me a sign-in link</button>
  </form>
  <p class="help">New here? Signing in creates your account automatically.</p>
</section>
<%- include('../partials/foot') %>
