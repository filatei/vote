<%- include('../partials/head') %>

<section class="landing-hero">
  <div class="landing-hero-text">
    <p class="eyebrow">Free &amp; fair online elections</p>
    <h1 class="landing-title">Run an election<br />anyone can trust</h1>
    <p class="landing-sub"><%= appName %> lets any group hold a secret-ballot election online in minutes — with verifiable receipts, so every voter can confirm their vote was counted.</p>
    <div class="landing-cta">
      <a class="button button-primary button-lg" href="/account/login">Create an election</a>
      <a class="button button-ghost button-lg" href="#vote">I have a voting code</a>
    </div>
    <p class="landing-note">No account needed to vote — just your code or election link.</p>
  </div>

  <div class="landing-visual">
    <% if (video && video.type === 'youtube') { %>
      <%# Lightweight click-to-play facade: only a tiny thumbnail loads up front,
          so the page is instant. The real player iframe is injected on click. %>
      <div class="video-wrap yt-facade" data-yt-embed="<%= video.src %>"
           role="button" tabindex="0" aria-label="Play the <%= appName %> explainer video">
        <img class="yt-thumb" src="https://i.ytimg.com/vi/<%= video.id %>/hqdefault.jpg"
             alt="" width="480" height="270" loading="eager" decoding="async"
             onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/<%= video.id %>/0.jpg'" />
        <span class="yt-play" aria-hidden="true"></span>
      </div>
      <noscript>
        <div class="video-wrap">
          <iframe src="<%= video.src %>" title="<%= appName %> — explainer"
                  loading="lazy" referrerpolicy="strict-origin-when-cross-origin"
                  allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen></iframe>
        </div>
      </noscript>
    <% } else if (video && video.type === 'file') { %>
      <video class="landing-video" controls preload="metadata" playsinline>
        <source src="<%= video.src %>" />
        Your browser can't play this video.
      </video>
    <% } else { %>
      <div class="explainer" role="img" aria-label="Animated illustration of casting a secret ballot">
        <svg viewBox="0 0 240 200" xmlns="http://www.w3.org/2000/svg">
          <!-- ballot box -->
          <rect x="40" y="96" width="160" height="84" rx="10" class="ex-box" />
          <rect x="92" y="92" width="56" height="10" rx="5" class="ex-slot" />
          <!-- ballot paper dropping in -->
          <g class="ex-paper">
            <rect x="96" y="20" width="48" height="60" rx="6" />
            <line x1="104" y1="34" x2="136" y2="34" />
            <line x1="104" y1="44" x2="136" y2="44" />
            <path d="M106 56 l6 6 l12 -14" class="ex-check" />
          </g>
          <!-- sparkles -->
          <circle cx="60" cy="60" r="3" class="ex-spark s1" />
          <circle cx="186" cy="48" r="3" class="ex-spark s2" />
          <circle cx="172" cy="150" r="3" class="ex-spark s3" />
        </svg>
        <p class="explainer-caption">A 60-second walkthrough video can go here.</p>
      </div>
    <% } %>
  </div>
</section>

<section class="options-grid">
  <div class="card option-card" id="vote">
    <div class="option-badge vote">Vote</div>
    <h2 class="h3">Cast your vote</h2>
    <p>Have a voting code or an election link? Enter your details below to cast a secret ballot. Your code is never linked to your choice.</p>
    <% if (error) { %><div class="alert alert-error" role="alert"><%= error %></div><% } %>
    <form method="post" action="/vote" class="stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label for="election">Election ID or link</label>
      <input id="election" name="election" type="text" autocomplete="off" value="<%= electionId || '' %>"
             placeholder="e.g. 3f1c… (from your invitation)" required />
      <label for="code">Voting code</label>
      <input id="code" name="code" type="text" autocomplete="off" spellcheck="false"
             placeholder="XXXX-XXXX-XXXX-XXXX" class="code-input" required />
      <button class="button button-primary" type="submit">Continue to ballot</button>
    </form>
  </div>

  <div class="card option-card create">
    <div class="option-badge create">Organise</div>
    <h2 class="h3">Run your own election</h2>
    <p>Create an election, add candidates with photos and bios, then invite voters — either with pre-issued codes or a single open link limited to one vote per device. Watch results come in live.</p>
    <ul class="tick-list">
      <li>Single or multiple-choice ballots</li>
      <li>Schedule open/close times</li>
      <li>Verifiable public results board</li>
    </ul>
    <a class="button button-primary button-lg full" href="/account/login">Sign in to get started</a>
    <p class="help">Passwordless — we email you a secure sign-in link.</p>
  </div>
</section>

<section class="faq">
  <h2 class="section-title">How it works &amp; FAQ</h2>

  <details class="faq-item" open>
    <summary>How do voters cast a ballot?</summary>
    <div class="faq-body">Open the election link or enter your voting code, choose your option, and submit. It works on any device or browser — no account needed.</div>
  </details>

  <details class="faq-item">
    <summary>Is my vote really secret?</summary>
    <div class="faq-body">Yes. Your code or device is never linked to the choice you make. Ballots are stored anonymously, so no one — not even an administrator — can tell how you voted.</div>
  </details>

  <details class="faq-item">
    <summary>How do you stop people voting twice?</summary>
    <div class="faq-body">Each pre-issued voting code can be used only once. For open-link elections, voting is limited to one ballot per device.</div>
  </details>

  <details class="faq-item">
    <summary>Can I check that my vote was counted?</summary>
    <div class="faq-body">Yes. After voting you get a receipt code. A public bulletin board lists every receipt, so you can confirm your ballot is included and anyone can audit the count.</div>
  </details>

  <details class="faq-item">
    <summary>How do I run my own election?</summary>
    <div class="faq-body">Sign in with a secure email link, add your question and candidates (with photos and bios), choose codes or an open link, and share it. Results tally live as votes come in.</div>
  </details>

  <details class="faq-item">
    <summary>What does it cost?</summary>
    <div class="faq-body">A flat one-time fee per election, shown at checkout. Voting is always free for voters.</div>
  </details>

  <details class="faq-item">
    <summary>What ballot types are supported?</summary>
    <div class="faq-body">Single choice and multiple-choice (approval) ballots, with optional scheduled open and close times in West Africa Time.</div>
  </details>
</section>
<%- include('../partials/foot') %>
