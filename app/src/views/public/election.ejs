<%- include('../partials/head') %>
<section class="hero">
  <h1><%= election.title %></h1>
  <% if (election.description) { %><p class="lead"><%= election.description %></p><% } %>
  <p class="status-pill status-<%= election.status %>"><%= election.status %></p>
</section>

<section class="card narrow">
  <% if (opensWat || closesWat) { %>
    <p class="window-note">
      <% if (opensWat) { %>Opens <strong><%= opensWat %></strong><% } %>
      <% if (opensWat && closesWat) { %> · <% } %>
      <% if (closesWat) { %>Closes <strong><%= closesWat %></strong><% } %>
    </p>
  <% } %>

  <% if (openMode && alreadyVoted) { %>
    <div class="alert alert-success" role="status">Thanks — a vote has already been recorded from this device.</div>
    <p class="lead">This election allows one vote per device, so you can't vote again here.</p>
  <% } else if (openMode && state.open) { %>
    <h2 class="h3">Ready to vote?</h2>
    <p class="lead">Anyone with this link can vote once per device.</p>
    <a class="button button-primary" href="/e/<%= election.public_id %>">Go to ballot</a>
  <% } else if (!openMode && state.open) { %>
    <h2 class="h3">Ready to vote?</h2>
    <form method="post" action="/vote" class="stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="election" value="<%= election.public_id %>" />
      <label for="code">Enter your voting code</label>
      <input id="code" name="code" type="text" autocomplete="off" spellcheck="false"
             placeholder="XXXX-XXXX-XXXX-XXXX" class="code-input" required />
      <button class="button button-primary" type="submit">Continue to ballot</button>
    </form>
  <% } else if (state.reason === 'before') { %>
    <p class="lead">Voting hasn't opened yet<% if (opensWat) { %> — it opens <strong><%= opensWat %></strong><% } %>. Please check back then.</p>
  <% } else if (state.reason === 'after' || state.reason === 'closed') { %>
    <p class="lead">This election is closed.</p>
  <% } else { %>
    <p class="lead">This election has not opened yet. Please check back later.</p>
  <% } %>
  <p class="links-row">
    <a href="/e/<%= election.public_id %>/results">View results</a>
    <span aria-hidden="true">·</span>
    <a href="/e/<%= election.public_id %>/verify">Verify a receipt</a>
  </p>
</section>
<%- include('../partials/foot') %>
