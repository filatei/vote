<%- include('../partials/head') %>
<section class="hero">
  <% if (election.logo_path) { %><img class="election-logo" src="/uploads/<%= election.logo_path %>" alt="" /><% } %>
  <h1>Results</h1>
  <p class="lead"><%= election.title %></p>
  <p class="status-pill status-<%= election.status %>"><%= election.status %></p>
</section>

<section class="card">
  <h2 class="h3">Leaderboard
    <span class="muted">(<span data-ballot-count><%= tally.totalBallots %></span> ballots)</span>
    <% if (election.status === 'open' && election.results_visibility === 'live') { %>
      <span class="live-dot" title="Updating live">Live</span>
    <% } %>
  </h2>
  <%
    var sorted = tally.rows.slice().sort(function(a, b){ return b.votes - a.votes; });
    var totalVotes = tally.rows.reduce(function(s, r){ return s + r.votes; }, 0);
    var maxVotes = sorted.length ? sorted[0].votes : 0;
  %>
  <ol class="leaderboard" data-results-poll data-public-id="<%= election.public_id %>"
      <%= election.status === 'open' && election.results_visibility === 'live' ? 'data-poll' : '' %>>
    <% sorted.forEach(function(r, i) {
         var pct = totalVotes ? Math.round((r.votes / totalVotes) * 100) : 0;
         var barPct = maxVotes ? Math.round((r.votes / maxVotes) * 100) : 0;
         var leader = i === 0 && r.votes > 0;
    %>
      <li class="lb-row<%= leader ? ' lb-leader' : '' %><%= r.description ? ' has-bio' : '' %>" data-option-id="<%= r.option_id %>">
        <span class="lb-rank"><%= i + 1 %></span>
        <% if (r.image_path) { %>
          <img class="lb-thumb" src="/uploads/<%= r.image_path %>" alt="" loading="lazy" />
        <% } else { %>
          <%- avatarSvg(r.label, r.option_id, 'lb-thumb') %>
        <% } %>
        <div class="lb-main">
          <div class="lb-top">
            <span class="lb-name"><%= r.label %><% if (leader) { %> <span class="lb-badge">Leading</span><% } %><% if (r.description) { %> <span class="lb-caret" aria-hidden="true">▾</span><% } %></span>
            <span class="lb-votes"><%= r.votes %><span class="lb-pct"><%= pct %>%</span></span>
          </div>
          <div class="bar"><div class="bar-fill" style="width: <%= barPct %>%"></div></div>
          <% if (r.description) { %><div class="lb-bio"><%= r.description %></div><% } %>
        </div>
      </li>
    <% }) %>
  </ol>
  <% if (election.ballot_type === 'multiple') { %>
    <p class="help">Approval ballot: voters could select up to <%= election.max_selections %> option(s), so percentages are of total votes cast, not of voters.</p>
  <% } %>
</section>

<section class="card">
  <div class="page-head" style="margin-bottom:10px;">
    <h2 class="h3">Bulletin board</h2>
    <a class="button button-ghost button-sm" href="/e/<%= election.public_id %>/integrity">Verify integrity</a>
  </div>
  <p class="help">Every anonymous ballot is listed by its receipt and a tamper-evident <strong>chain hash</strong> (each includes the previous ballot's hash). Find your receipt to confirm it's counted; anyone can <a href="/e/<%= election.public_id %>/integrity">recompute the chain</a> to prove nothing was altered.</p>
  <div class="table-scroll">
    <table class="data-table">
      <thead><tr><th>Receipt</th><th>Date</th><th>Choice(s)</th><th>Chain hash</th></tr></thead>
      <tbody>
        <% if (board.length === 0) { %>
          <tr><td colspan="4" class="muted">No ballots yet.</td></tr>
        <% } %>
        <% board.forEach(function(b) { %>
          <tr>
            <td><code><%= b.receipt_code %></code></td>
            <td><%= b.cast_date %></td>
            <td><%= b.options.join(', ') %></td>
            <td><code class="muted"><%= b.chain_hash ? b.chain_hash.slice(0, 12) + '…' : '—' %></code></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/foot') %>
