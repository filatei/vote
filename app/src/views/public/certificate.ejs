<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/static/css/style.css?v=<%= assetVer %>" />
</head>
<body class="cert-page">
  <div class="cert-toolbar">
    <a class="button button-ghost button-sm" href="/e/<%= election.public_id %>/results">← Back to results</a>
    <button class="button button-primary button-sm" type="button" data-print>Print / Save as PDF</button>
  </div>

  <div class="certificate">
    <div class="cert-frame">
      <div class="cert-brand">
        <svg class="cert-logo" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="2" width="36" height="36" rx="11" fill="#15a05a"/>
          <path d="M11.5 20.5l5.5 5.5L29 13" fill="none" stroke="#fff" stroke-width="4.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Torama&nbsp;Vote</span>
      </div>

      <h1 class="cert-title">Certificate of Return</h1>
      <div class="cert-rule"></div>

      <p class="cert-intro">This is to certify that</p>

      <% if (win.winner.image_path) { %>
        <img class="cert-photo" src="/uploads/<%= win.winner.image_path %>" alt="" />
      <% } %>

      <p class="cert-winner"><%= win.winner.label %></p>
      <% if (win.winner.party) { %><p class="cert-party"><%= win.winner.party %></p><% } %>

      <p class="cert-text">
        having polled the highest number of votes cast, is hereby declared the
        winner of <strong><%= election.title %></strong>, an online poll
        conducted on Torama&nbsp;Vote.
      </p>

      <div class="cert-stats">
        <div class="cert-stat"><span class="cert-stat-num"><%= win.winner.votes %></span><span class="cert-stat-lbl">Votes</span></div>
        <div class="cert-stat"><span class="cert-stat-num"><%= win.pct %>%</span><span class="cert-stat-lbl">Share</span></div>
        <div class="cert-stat"><span class="cert-stat-num"><%= win.totalVotes %></span><span class="cert-stat-lbl">Total votes</span></div>
      </div>

      <div class="cert-foot">
        <div class="cert-seal" aria-hidden="true">
          <svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
            <circle cx="45" cy="45" r="42" fill="none" stroke="#15a05a" stroke-width="3"/>
            <circle cx="45" cy="45" r="34" fill="none" stroke="#15a05a" stroke-width="1.5" stroke-dasharray="2 3"/>
            <path d="M33 46l8 8 16-19" fill="none" stroke="#15a05a" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="cert-issuer">
          <p class="cert-issuer-name">Issued by Torama&nbsp;Vote</p>
          <% if (closedWat) { %><p class="cert-meta">Voting closed <%= closedWat %> (WAT)</p><% } %>
          <p class="cert-meta">Verify at <%= baseUrl.replace(/^https?:\/\//, '') %>/e/<%= election.public_id %></p>
        </div>
      </div>

      <p class="cert-disclaimer">
        This is an <strong>informal online opinion poll</strong> conducted on
        Torama&nbsp;Vote. It is <strong>not</strong> an official election result and is
        not affiliated with INEC or any government body. The result is independently
        verifiable via the public bulletin board.
      </p>
    </div>
  </div>

  <script src="/static/js/app.js?v=<%= assetVer %>"></script>
</body>
</html>
