<%- include('../partials/head') %>
<section class="hero">
  <% if (election.logo_path) { %><img class="election-logo" src="/uploads/<%= election.logo_path %>" alt="" /><% } %>
  <h1><%= election.title %></h1>
  <% if (election.description) { %><p class="lead"><%= election.description %></p><% } %>
</section>

<section class="card">
  <% if (error) { %><div class="alert alert-error" role="alert"><%= error %></div><% } %>

  <% if (election.ballot_type === 'single') { %>
    <p class="ballot-instruction">Select <strong>one</strong> option.</p>
  <% } else { %>
    <p class="ballot-instruction">Select up to <strong><%= election.max_selections %></strong> option(s).</p>
  <% } %>

  <form method="post" action="/cast" class="stack ballot-form"
        data-ballot-type="<%= election.ballot_type %>"
        data-max="<%= election.max_selections %>" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="election" value="<%= election.public_id %>" />
    <% if (codeMode === 'hidden') { %>
      <input type="hidden" name="code" value="<%= code %>" />
    <% } else if (codeMode === 'optional') { %>
      <div class="code-optional">
        <label for="code">Have a voting code? <span class="muted">(optional)</span></label>
        <input id="code" name="code" type="text" autocomplete="off" spellcheck="false"
               class="code-input" value="<%= code %>" placeholder="XXXX-XXXX-XXXX-XXXX" />
        <p class="help">Enter your code to vote with it, or leave it blank to vote once from this device.</p>
      </div>
    <% } %>

    <fieldset class="options">
      <legend class="sr-only">Ballot options</legend>
      <% election.options.forEach(function(opt) { %>
        <label class="option candidate">
          <input class="option-native" type="<%= election.ballot_type === 'single' ? 'radio' : 'checkbox' %>"
                 name="option" value="<%= opt.id %>" />
          <% if (opt.image_path) { %>
            <img class="option-thumb" src="/uploads/<%= opt.image_path %>" alt="" loading="lazy" />
          <% } else { %>
            <%- avatarSvg(opt.label, opt.id) %>
          <% } %>
          <span class="option-body">
            <span class="option-label"><%= opt.label %></span>
            <% if (opt.description) { %><span class="option-sub"><%= opt.description %></span><% } %>
          </span>
          <span class="option-check" aria-hidden="true"></span>
        </label>
      <% }) %>
    </fieldset>

    <p class="help" data-selection-hint hidden></p>

    <div class="actions">
      <button class="button button-primary" type="submit">Cast my vote</button>
      <a class="button button-ghost" href="/e/<%= election.public_id %>">Cancel</a>
    </div>
    <% if (codeMode === 'none') { %>
      <p class="help">Anyone with this link can vote, but only once per device. Once you submit, your ballot is final.</p>
    <% } else if (codeMode === 'optional') { %>
      <p class="help">Once you submit, your ballot is final.</p>
    <% } else { %>
      <p class="help">Once you submit, your code is spent and your ballot is final.</p>
    <% } %>
  </form>
</section>
<%- include('../partials/foot') %>
