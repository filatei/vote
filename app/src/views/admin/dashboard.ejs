<%- include('../partials/head') %>
<section class="page-head">
  <div>
    <h1>Elections</h1>
    <p class="page-sub muted">Manage every election on the platform.</p>
  </div>
  <div class="button-row">
    <a class="button button-ghost" href="/admin/stats">Analytics</a>
    <a class="button button-ghost" href="/admin/payments">Payments</a>
    <a class="button button-ghost" href="/admin/email">Email settings</a>
    <a class="button button-primary btn-icon" href="/admin/elections/new">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
      New election
    </a>
  </div>
</section>

<section class="card setting-card">
  <div class="setting-row">
    <div>
      <h2 class="h3">Monetisation <span class="status-pill status-<%= monetiseOn ? 'open' : 'draft' %>" style="vertical-align:middle;margin-left:6px;">MONETISE <%= monetiseOn ? 'ON' : 'OFF' %></span></h2>
      <p class="muted" style="margin:4px 0 0;">
        Creating an election is always free. When monetisation is <strong>ON</strong>, the creator must pay the per‑voter launch fee before they can <strong>open</strong> an election for voting. Elections in the free voter tier still open at no charge.
      </p>
      <% if (monetiseOn && !providerConfigured) { %>
        <p class="alert alert-warn" style="margin-top:8px;">Monetise is ON, but no payment rail is configured — opening a paid election will fail until Squad (or Monnify) keys are set in <code>.env</code>.</p>
      <% } %>
    </div>
    <div class="setting-action">
      <form method="post" action="/admin/settings/monetise" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="enabled" value="<%= monetiseOn ? '0' : '1' %>" />
        <button class="button <%= monetiseOn ? 'button-danger' : 'button-primary' %>" type="submit">
          <%= monetiseOn ? 'Turn monetise OFF' : 'Turn monetise ON' %>
        </button>
      </form>
    </div>
  </div>
</section>

<section class="card setting-card">
  <div class="setting-row">
    <div>
      <h2 class="h3">Election deletion</h2>
      <p class="muted" style="margin:4px 0 0;">
        When on, election owners (and admins) can permanently delete elections. When off, opened elections can only be closed — deletion is blocked to protect records.
      </p>
    </div>
    <div class="setting-action">
      <span class="status-pill status-<%= deleteEnabled ? 'open' : 'draft' %>"><%= deleteEnabled ? 'On' : 'Off' %></span>
      <form method="post" action="/admin/settings/election-delete" class="inline-form"
            <% if (!deleteEnabled) { %>data-confirm="Allow permanent deletion of elections, including ones with votes?"<% } %>>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="enabled" value="<%= deleteEnabled ? '0' : '1' %>" />
        <button class="button <%= deleteEnabled ? 'button-danger' : 'button-primary' %>" type="submit">
          <%= deleteEnabled ? 'Disable' : 'Enable' %> deletion
        </button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/election_list', { elections: elections, basePath: '/admin', showResults: true }) %>
<%- include('../partials/foot') %>
