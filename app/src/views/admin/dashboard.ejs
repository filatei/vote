<%- include('../partials/head') %>
<section class="page-head">
  <div>
    <h1>Elections</h1>
    <p class="page-sub muted">Manage every election on the platform.</p>
  </div>
  <div class="button-row">
    <a class="button button-ghost" href="/admin/stats">Analytics</a>
    <a class="button button-ghost" href="/admin/payments">Payments</a>
    <a class="button button-ghost" href="/admin/email">Email settings</a>
    <a class="button button-primary btn-icon" href="/admin/elections/new">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
      New election
    </a>
  </div>
</section>

<section class="card setting-card">
  <div class="setting-row">
    <div>
      <h2 class="h3">Paid subscriptions</h2>
      <p class="muted" style="margin:4px 0 0;">
        When on, election creators need an active subscription to <strong>open</strong> an election (creating stays free).
      </p>
      <% if (subsToggledOn && !lsConfigured) { %>
        <p class="alert alert-warn" style="margin-top:8px;">Toggle is on, but Lemon Squeezy isn't configured — gating is inactive until the LS keys are set in <code>.env</code>.</p>
      <% } %>
    </div>
    <div class="setting-action">
      <span class="status-pill status-<%= subsActive ? 'open' : 'draft' %>"><%= subsActive ? 'On' : 'Off' %></span>
      <form method="post" action="/admin/settings/subscriptions" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="enabled" value="<%= subsToggledOn ? '0' : '1' %>" />
        <button class="button <%= subsToggledOn ? 'button-danger' : 'button-primary' %>" type="submit">
          <%= subsToggledOn ? 'Disable' : 'Enable' %> subscriptions
        </button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/election_list', { elections: elections, basePath: '/admin', showResults: true }) %>
<%- include('../partials/foot') %>
