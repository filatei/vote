<%- include('../partials/head') %>
<section class="page-head">
  <h1>New election</h1>
  <a class="button button-ghost" href="<%= basePath %>">Cancel</a>
</section>

<section class="card">
  <% if (error) { %><div class="alert alert-error" role="alert"><%= error %></div><% } %>
  <form method="post" action="<%= basePath %>/elections" class="stack" id="election-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <label for="title">Title</label>
    <input id="title" name="title" type="text" required maxlength="200"
           value="<%= form ? form.title : '' %>" />

    <label for="description">Description <span class="muted">(optional)</span></label>
    <textarea id="description" name="description" rows="3" maxlength="5000"><%= form ? form.description : '' %></textarea>

    <fieldset class="inline-fieldset">
      <legend>What kind of election is this?</legend>
      <% var selType = (form && form.electionType) ? form.electionType : 'candidates'; %>
      <div class="type-grid">
        <% electionTypeList().forEach(function(t) { %>
          <label class="type-card">
            <input type="radio" name="electionType" value="<%= t.key %>" <%= selType === t.key ? 'checked' : '' %> />
            <span class="type-card-name"><%= t.name %></span>
            <span class="type-card-hint"><%= t.hint %></span>
          </label>
        <% }) %>
      </div>
    </fieldset>

    <fieldset class="inline-fieldset">
      <legend>Ballot type</legend>
      <div class="type-grid">
        <label class="type-card">
          <input type="radio" name="ballotType" value="single"
                 <%= !form || form.ballotType !== 'multiple' ? 'checked' : '' %> data-ballot-toggle />
          <span class="type-card-name">Single choice</span>
          <span class="type-card-hint">Voters pick exactly one option.</span>
        </label>
        <label class="type-card">
          <input type="radio" name="ballotType" value="multiple"
                 <%= form && form.ballotType === 'multiple' ? 'checked' : '' %> data-ballot-toggle />
          <span class="type-card-name">Multiple choice</span>
          <span class="type-card-hint">Approval — voters can pick several.</span>
        </label>
      </div>
    </fieldset>

    <div data-max-wrap <%= (form && form.ballotType === 'multiple') ? '' : 'hidden' %>>
      <label for="maxSelections">Maximum selections allowed</label>
      <input id="maxSelections" name="maxSelections" type="number" inputmode="numeric" min="1" max="50" step="1"
             value="<%= form && form.maxSelections ? form.maxSelections : 2 %>" />
    </div>

    <fieldset class="inline-fieldset">
      <legend>Who can vote?</legend>
      <div class="type-grid">
        <label class="type-card">
          <input type="radio" name="accessMode" value="open"
                 <%= (!form || !form.accessMode || form.accessMode === 'open') ? 'checked' : '' %> />
          <span class="type-card-name">Open link — one vote per device</span>
          <span class="type-card-hint">Anyone with the link votes, limited to one per device. Quickest to run.</span>
        </label>
        <label class="type-card">
          <input type="radio" name="accessMode" value="code"
                 <%= form && form.accessMode === 'code' ? 'checked' : '' %> />
          <span class="type-card-name">Pre-issued voting codes</span>
          <span class="type-card-hint">One code = one vote — the strongest guarantee. Best for high-stakes elections.</span>
        </label>
        <label class="type-card">
          <input type="radio" name="accessMode" value="hybrid"
                 <%= form && form.accessMode === 'hybrid' ? 'checked' : '' %> />
          <span class="type-card-name">Link + codes (hybrid)</span>
          <span class="type-card-hint">People with a code use it; everyone else votes once per device via the link.</span>
        </label>
      </div>
    </fieldset>

    <fieldset class="inline-fieldset">
      <legend>When are results visible?</legend>
      <div class="type-grid">
        <label class="type-card">
          <input type="radio" name="resultsVisibility" value="after_close"
                 <%= !form || form.resultsVisibility !== 'live' ? 'checked' : '' %> />
          <span class="type-card-name">After the election closes</span>
          <span class="type-card-hint">The tally stays hidden until voting ends.</span>
        </label>
        <label class="type-card">
          <input type="radio" name="resultsVisibility" value="live"
                 <%= form && form.resultsVisibility === 'live' ? 'checked' : '' %> />
          <span class="type-card-name">Live results</span>
          <span class="type-card-hint">The tally updates as votes come in.</span>
        </label>
      </div>
    </fieldset>

    <fieldset class="inline-fieldset">
      <legend>Voting window <span class="muted">(optional, times in WAT)</span></legend>
      <div class="schedule-grid">
        <div>
          <label for="opensAt">Opens</label>
          <input id="opensAt" name="opensAt" type="datetime-local"
                 value="<%= form && form.opensAt ? form.opensAt : '' %>" />
        </div>
        <div>
          <label for="closesAt">Closes</label>
          <input id="closesAt" name="closesAt" type="datetime-local"
                 value="<%= form && form.closesAt ? form.closesAt : '' %>" />
        </div>
      </div>
      <p class="help">Leave blank to control opening/closing manually. When set, votes are only accepted between these West Africa Time (UTC+1) times while the election is open.</p>
    </fieldset>

    <fieldset class="inline-fieldset">
      <legend>Registered voters <span class="muted">(for pricing)</span></legend>
      <label for="enrolledVoters">How many voters will be eligible?</label>
      <input id="enrolledVoters" name="enrolledVoters" type="number" inputmode="numeric" min="0" step="1"
             value="<%= form && form.enrolledVoters ? form.enrolledVoters : 20 %>" />
      <p class="help">This is the billable count. Pricing is per registered voter, with the rate set by the total (the first 10 voters are free). You can adjust it before you launch.</p>
    </fieldset>

    <label>Options <span class="muted">(at least two)</span></label>
    <div id="options-list" class="options-editor">
      <% var opts = (form && form.options && form.options.length) ? form.options : ['', '']; %>
      <% opts.forEach(function(o) { %>
        <input class="option-input" type="text" name="option" maxlength="200" value="<%= o %>" placeholder="Option label" />
      <% }) %>
    </div>
    <button type="button" class="button button-ghost" id="add-option">+ Add option</button>

    <button class="button button-primary" type="submit">Create election</button>
  </form>
</section>
<%- include('../partials/foot') %>
