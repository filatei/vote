<%- include('../partials/head') %>
<section class="page-head">
  <h1>Payments</h1>
  <a class="button button-ghost" href="/admin">← Dashboard</a>
</section>

<section class="card">
  <div class="table-scroll">
    <table class="data-table">
      <thead><tr><th>Date</th><th>Election</th><th>Email</th><th>Amount</th><th>Provider</th><th>Status</th><th>Reference</th></tr></thead>
      <tbody>
        <% if (payments.length === 0) { %>
          <tr><td colspan="7" class="muted">No payments yet.</td></tr>
        <% } %>
        <% payments.forEach(function(p) { %>
          <tr>
            <td class="muted"><%= new Date(p.created_at).toISOString().slice(0,10) %></td>
            <td><%= p.election_title || '—' %></td>
            <td class="muted"><%= p.email %></td>
            <td><%= formatAmount(p.amount_subunits, p.currency) %></td>
            <td class="muted"><%= p.provider || 'paystack' %></td>
            <td>
              <span class="status-pill <%= p.status === 'confirmed' ? 'status-open' : p.status === 'failed' ? 'status-closed' : 'status-draft' %>"><%= p.status %></span>
            </td>
            <td><code class="muted"><%= p.reference %></code></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/foot') %>
