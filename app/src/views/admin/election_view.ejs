<%- include('../partials/head') %>
<section class="page-head">
  <div>
    <h1><%= election.title %></h1>
    <p class="status-pill status-<%= election.status %>"><%= election.status %></p>
  </div>
  <a class="button button-ghost" href="<%= basePath %>">← All elections</a>
</section>

<% if (generatedCodes && generatedCodes.length) { %>
<section class="card highlight-card">
  <h2 class="h3">Voting codes generated — shown once</h2>
  <div class="alert alert-warn" role="alert">
    These <strong><%= generatedCodes.length %></strong> codes are displayed only now. Download the CSV
    and distribute them. They are stored only as hashes and cannot be retrieved again.
  </div>
  <form method="post" action="<%= basePath %>/elections/<%= election.id %>/codes.csv">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <% generatedCodes.forEach(function(c) { %><input type="hidden" name="code" value="<%= c %>" /><% }) %>
    <button class="button button-primary" type="submit">Download CSV</button>
    <button class="button button-ghost" type="button" id="copy-codes">Copy all</button>
  </form>
  <pre class="code-dump" id="code-dump"><% generatedCodes.forEach(function(c){ %><%= c %>
<% }) %></pre>
</section>
<% } %>

<div class="grid-2">
  <section class="card">
    <h2 class="h3">Status</h2>
    <p class="help">Ballots are accepted only while <strong>open</strong>.</p>
    <div class="button-row">
      <% ['draft','open','closed'].forEach(function(s) { %>
        <form method="post" action="<%= basePath %>/elections/<%= election.id %>/status" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="status" value="<%= s %>" />
          <button class="button <%= election.status === s ? 'button-primary' : 'button-ghost' %>"
                  type="submit" <%= election.status === s ? 'disabled' : '' %>><%= s %></button>
        </form>
      <% }) %>
    </div>
  </section>

  <section class="card">
    <h2 class="h3">Voting window <span class="muted">(WAT)</span></h2>
    <form method="post" action="<%= basePath %>/elections/<%= election.id %>/schedule" class="stack">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="schedule-grid">
        <div>
          <label for="opensAt">Opens</label>
          <input id="opensAt" name="opensAt" type="datetime-local"
                 value="<%= toWatInput(election.opens_at) %>" />
        </div>
        <div>
          <label for="closesAt">Closes</label>
          <input id="closesAt" name="closesAt" type="datetime-local"
                 value="<%= toWatInput(election.closes_at) %>" />
        </div>
      </div>
      <p class="help">
        <% if (election.opens_at || election.closes_at) { %>
          Now: opens <strong><%= election.opens_at ? formatWat(election.opens_at) : 'manual' %></strong>,
          closes <strong><%= election.closes_at ? formatWat(election.closes_at) : 'manual' %></strong>.
        <% } else { %>
          No window set — opening/closing is manual.
        <% } %>
      </p>
      <button class="button button-ghost" type="submit">Save window</button>
    </form>
  </section>

  <section class="card">
    <h2 class="h3">Share link</h2>
    <p class="help">Send voters here, with their code:</p>
    <p class="share-url"><code><%= baseUrl %>/e/<%= election.public_id %></code></p>
    <p class="links-row">
      <a href="/e/<%= election.public_id %>" target="_blank" rel="noopener">Open voter page ↗</a>
      <span aria-hidden="true">·</span>
      <a href="/e/<%= election.public_id %>/results" target="_blank" rel="noopener">Results ↗</a>
    </p>
    <p class="links-row">
      <a href="<%= basePath %>/elections/<%= election.id %>/contestants">Manage contestant photos &amp; bios →</a>
    </p>
  </section>
</div>

<% if (election.access_mode === 'open') { %>
<section class="card">
  <h2 class="h3">Open-link voting</h2>
  <p class="help">Anyone with the share link can vote, limited to <strong>one vote per device</strong> (cookie + device fingerprint). No codes needed — just share the link. Note: this is convenient but a determined person could clear cookies and switch networks; use code-based elections for high-stakes votes.</p>
  <p class="share-url"><code><%= baseUrl %>/e/<%= election.public_id %></code></p>
</section>
<% } else { %>
<section class="card">
  <h2 class="h3">Voting codes</h2>
  <div class="stat-row">
    <div class="stat"><span class="stat-num"><%= codeStats.total %></span><span class="stat-label">issued</span></div>
    <div class="stat"><span class="stat-num"><%= codeStats.used %></span><span class="stat-label">used</span></div>
    <div class="stat"><span class="stat-num"><%= codeStats.unused %></span><span class="stat-label">unused</span></div>
  </div>
  <% if (election.status !== 'closed') { %>
    <form method="post" action="<%= basePath %>/elections/<%= election.id %>/codes" class="inline-form-wide">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label for="count" class="sr-only">Number of codes</label>
      <input id="count" name="count" type="number" min="1" max="50000" value="50" />
      <button class="button button-primary" type="submit">Generate codes</button>
    </form>
  <% } else { %>
    <p class="muted">Election closed — code generation disabled.</p>
  <% } %>
</section>
<% } %>

<section class="card">
  <h2 class="h3">Live tally <span class="muted">(<%= tally.totalBallots %> ballots)</span></h2>
  <% var max = tally.rows.reduce(function(m, r){ return Math.max(m, r.votes); }, 0) || 1; %>
  <ul class="results">
    <% tally.rows.forEach(function(r) { %>
      <li class="result-row">
        <div class="result-head"><span class="result-label"><%= r.label %></span><span class="result-count"><%= r.votes %></span></div>
        <div class="bar"><div class="bar-fill" style="width: <%= Math.round((r.votes / max) * 100) %>%"></div></div>
      </li>
    <% }) %>
  </ul>
</section>

<section class="card">
  <h2 class="h3">Audit log</h2>
  <div class="table-scroll">
    <table class="data-table">
      <thead><tr><th>When</th><th>Who</th><th>Action</th><th>Detail</th></tr></thead>
      <tbody>
        <% if (audit.length === 0) { %><tr><td colspan="4" class="muted">No actions logged.</td></tr><% } %>
        <% audit.forEach(function(a) { %>
          <tr>
            <td class="muted"><%= new Date(a.created_at).toISOString().replace('T',' ').slice(0,19) %></td>
            <td><%= a.username || '—' %></td>
            <td><%= a.action %></td>
            <td class="muted"><%= JSON.stringify(a.detail) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<section class="card danger-zone">
  <h2 class="h3">Danger zone</h2>
  <% if (canDelete) { %>
    <p class="help">
      <% if (allowDeleteAny) { %>
        Testing mode: this permanently deletes the election and all its codes and ballots. This cannot be undone.
      <% } else { %>
        This election is still a draft (never opened), so it can be deleted. Once opened it can only be closed.
      <% } %>
    </p>
    <form method="post" action="<%= basePath %>/elections/<%= election.id %>/delete"
          class="confirm-delete" data-confirm="Permanently delete &quot;<%= election.title %>&quot; and all its data? This cannot be undone.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="button button-danger" type="submit">Delete this election</button>
    </form>
  <% } else { %>
    <p class="help">This election has been opened, so it can no longer be deleted — use <strong>Close</strong> in the Status panel to end it. Its record is preserved for audit.</p>
  <% } %>
</section>
<%- include('../partials/foot') %>
