<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light" />
  <%
    // Public, shareable pages (landing, ballot, results) opt in to indexing and
    // rich link previews; everything else (admin/account) stays private.
    var _pub = (typeof publicPage !== 'undefined' && publicPage);
  %>
  <% if (_pub) { %>
    <meta name="robots" content="index,follow" />
  <% } else { %>
    <meta name="robots" content="noindex" />
  <% } %>
  <title><%= typeof title !== 'undefined' ? title : 'Torama Vote' %></title>
  <% if (_pub) {
       var _base = (typeof baseUrl !== 'undefined' ? baseUrl : '');
       var _img = (typeof ogImage !== 'undefined' && ogImage) ? ogImage
                : (typeof election !== 'undefined' && election && election.logo_path) ? ('/uploads/' + election.logo_path)
                : '/static/og-default.png';
       if (_img.charAt(0) === '/') _img = _base + _img;
       var _desc = (typeof ogDescription !== 'undefined' && ogDescription) ? ogDescription
                 : (typeof election !== 'undefined' && election && election.description) ? election.description
                 : 'Run a free & fair online election in minutes — secret ballot with verifiable receipts.';
       var _url = (typeof currentUrl !== 'undefined') ? currentUrl : _base;
       var _title = (typeof ogTitle !== 'undefined' && ogTitle) ? ogTitle : (typeof title !== 'undefined' ? title : 'Torama Vote');
  %>
    <meta name="description" content="<%= _desc %>" />
    <link rel="canonical" href="<%= _url %>" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Torama Vote" />
    <meta property="og:title" content="<%= _title %>" />
    <meta property="og:description" content="<%= _desc %>" />
    <meta property="og:image" content="<%= _img %>" />
    <meta property="og:url" content="<%= _url %>" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= _title %>" />
    <meta name="twitter:description" content="<%= _desc %>" />
    <meta name="twitter:image" content="<%= _img %>" />
  <% } %>
  <link rel="stylesheet" href="/static/css/style.css?v=<%= typeof assetVer !== 'undefined' ? assetVer : '1' %>" />
  <link rel="icon" href="/static/favicon.svg?v=<%= typeof assetVer !== 'undefined' ? assetVer : '1' %>" type="image/svg+xml" />
  <link rel="alternate icon" href="/static/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" href="/static/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#2f6df4" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="Torama Vote" />
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>
<header class="site-header">
  <div class="container header-row">
    <a class="brand" href="/">
      <svg class="brand-logo" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="tvh" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#3b82f6"/>
            <stop offset="1" stop-color="#1f50c0"/>
          </linearGradient>
        </defs>
        <rect x="2" y="2" width="36" height="36" rx="11" fill="url(#tvh)"/>
        <path d="M11.5 20.5l5.5 5.5L29 13" fill="none" stroke="#fff" stroke-width="4.2"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="brand-name">Torama&nbsp;Vote</span>
    </a>
    <% if (typeof adminUsername !== 'undefined' && adminUsername) { %>
      <nav class="header-nav">
        <a href="/admin">Dashboard</a>
        <form method="post" action="/admin/logout" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
          <button class="link-button" type="submit">Sign out</button>
        </form>
      </nav>
    <% } else if (typeof customerEmail !== 'undefined' && customerEmail) { %>
      <nav class="header-nav">
        <a href="/account">Dashboard</a>
        <span class="muted nav-email"><%= customerEmail %></span>
        <form method="post" action="/account/logout" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
          <button class="link-button" type="submit">Sign out</button>
        </form>
      </nav>
    <% } else { %>
      <nav class="header-nav">
        <a class="button button-ghost button-sm" href="/account/login">Sign in</a>
      </nav>
    <% } %>
  </div>
</header>
<main id="main" class="container">
