<%
  // Reusable election list (account + admin). Locals: elections, basePath,
  // and optional showResults (admin shows results visibility).
  var showResults = (typeof showResults !== 'undefined') ? showResults : false;
  var ic = {
    ballot: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="4"/><path d="M8 12.4l2.6 2.6L16 9"/></svg>',
    single: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3.2" fill="currentColor" stroke="none"/></svg>',
    multiple: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10 6h10M10 12h10M10 18h10"/><path d="M4 6.3l1.2 1.2L7.6 5M4 12.3l1.2 1.2L7.6 11M4 18.3l1.2 1.2L7.6 17"/></svg>',
    link: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7 0l2-2a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-2 2a5 5 0 0 0 7 7l1-1"/></svg>',
    key: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="15" r="4"/><path d="M10.9 12.1L20 3M17 6l2 2M14 9l2 2"/></svg>',
    live: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2.5"/><path d="M6.8 6.8a8 8 0 0 0 0 10.4M17.2 6.8a8 8 0 0 1 0 10.4"/></svg>',
    lock: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>',
    chevron: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>'
  };
%>
<% if (!elections || elections.length === 0) { %>
  <section class="card empty-state">
    <span class="empty-icon"><%- ic.ballot %></span>
    <h2 class="h3">No elections yet</h2>
    <p class="muted">Create your first poll — add candidates, share a link, and watch the results come in live.</p>
    <a class="button button-primary" href="<%= basePath %>/elections/new">+ New election</a>
  </section>
<% } else { %>
  <ul class="election-list">
    <% elections.forEach(function(e) {
         var typeLabel = e.ballot_type === 'single' ? 'Single choice' : 'Multiple (max ' + e.max_selections + ')';
         var typeIcon = e.ballot_type === 'single' ? ic.single : ic.multiple;
         var accessLabel = e.access_mode === 'open' ? 'Open link' : e.access_mode === 'hybrid' ? 'Link + codes' : 'Codes';
         var accessIcon = e.access_mode === 'codes' ? ic.key : ic.link;
    %>
      <li>
        <a class="election-item" href="<%= basePath %>/elections/<%= e.id %>">
          <span class="ei-icon" data-status="<%= e.status %>"><%- ic.ballot %></span>
          <span class="ei-body">
            <span class="ei-title"><%= e.title %></span>
            <span class="ei-meta">
              <span class="ei-chip"><%- typeIcon %><span><%= typeLabel %></span></span>
              <span class="ei-chip"><%- accessIcon %><span><%= accessLabel %></span></span>
              <% if (showResults) { %>
                <span class="ei-chip"><%- e.results_visibility === 'live' ? ic.live : ic.lock %><span><%= e.results_visibility === 'live' ? 'Live results' : 'Results after close' %></span></span>
              <% } %>
            </span>
          </span>
          <span class="ei-right">
            <span class="status-pill status-<%= e.status %>"><%= e.status %></span>
            <span class="ei-chev"><%- ic.chevron %></span>
          </span>
        </a>
      </li>
    <% }); %>
  </ul>
<% } %>
