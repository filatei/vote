# Vote's own ingress. Cloudflare proxies vote.torama.money to this Caddy on
# :2053 (via a Cloudflare Origin Rule that sets the origin port), so Vote never
# touches the shared Apache. Caddy serves HTTPS with a Cloudflare Origin
# Certificate and reverse-proxies the app over the private docker network.
#
# 2053 is one of Cloudflare's proxy-compatible HTTPS origin ports
# (443, 2053, 2083, 2087, 2096, 8443). neflo uses 8443, daybook 2083,
# otuburu 2087.

{
	admin off
	# Trust Cloudflare's forwarded client IP (so {remote_host} / X-Forwarded-For
	# is the real visitor — Vote needs it for one-vote-per-device + rate limits).
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
	}
}

vote.torama.money:2053 {
	# Cloudflare Origin Certificate (15-year) for *.torama.money.
	tls /etc/caddy/origin/cert.pem /etc/caddy/origin/key.pem

	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server
	}

	reverse_proxy vote_app:8090 {
		# flush_interval -1 keeps any streamed responses unbuffered.
		flush_interval -1
		header_up X-Forwarded-Proto https
		header_up Host {host}
	}
}
