# ─────────────────────────────────────────────────────────────
# Verita — environment configuration
# Copy to .env and fill in real secrets. NEVER commit .env.
# Generate strong secrets, e.g.:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Branding ──────────────────────────────────────────────────
# Product name shown across the UI, emails, certificates and meta tags.
# Single source of truth — change it here, nowhere else.
APP_NAME=Verita
APP_LEGAL_NAME=TORAMA Global Services Limited
APP_TAGLINE=secret ballot with verifiable receipts

# Port the Node app listens on inside its container, and that Apache proxies to.
# Pick a port not used by other apps on the shared Linode host.
APP_PORT=8090

# Public base URL (used for building absolute links in pages/receipts).
PUBLIC_BASE_URL=https://vote.torama.money

# Landing-page explainer video. A YouTube link (youtu.be/… or youtube.com/watch?v=…)
# is embedded as an iframe; a direct .mp4/.webm URL uses an HTML5 player.
# Defaults to the Torama Vote YouTube clip if left blank.
LANDING_VIDEO_URL=https://youtu.be/Cafnwp8FElk

# Set to "true" once running behind Apache/HTTPS so secure cookies + proxy
# headers are trusted.
TRUST_PROXY=true

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=votedb
POSTGRES_USER=voteuser
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# host is the docker service name on the internal network
POSTGRES_HOST=vote_postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=vote_redis
REDIS_PORT=6379

# ── Application secrets ───────────────────────────────────────
# Session signing secret (admin login sessions).
SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32
# CSRF token secret.
CSRF_SECRET=CHANGE_ME_openssl_rand_hex_32
# Server-side pepper mixed into voting-code hashes. If this leaks AND the DB
# leaks, codes could be brute-forced offline, so keep it secret and back it up
# — losing it makes existing codes unredeemable.
CODE_PEPPER=CHANGE_ME_openssl_rand_hex_32

# ── Admin Google Sign-In (OIDC) ───────────────────────────────────────────
# When set, /admin is gated behind Google sign-in restricted to the emails
# below. Use the OAuth "Web application" client for vote.torama.money. Add this
# redirect URI to that client: https://vote.torama.money/admin/auth/google/callback
# Leave blank to fall back to username/password admin login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://vote.torama.money/admin/auth/google/callback
ADMIN_ALLOWED_EMAILS=filatei@gmail.com,filatei@torama.money

# ── Email (transactional: magic-links, sending election URLs) ─────────────
# Default target is Google Workspace SMTP relay — the same service the other
# torama.money apps (otuburu, tax server) use. Because vote runs on the same
# server IP, the relay authorises it by IP, so NO username/password is needed.
# Leave SMTP_HOST blank to run in "log mode" (emails printed to the logs).
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=            # leave blank for IP-authorised relay
# SMTP_PASS=
MAIL_FROM=Verita <no-reply@torama.money>

# ── Payments (pay-before-launch, per-voter pricing) ───────────────────────
# Master switch for the launch paywall. false = elections are free to open
# (default). Set true (with a configured rail below) to require payment.
PAYMENTS_ENABLED=false
# Currency the metered price is charged in (Squad supports NGN & USD).
PAYMENT_CURRENCY=NGN
# Preferred rail: "squad" (primary) or "monnify". The other is used
# automatically as a fallback when the preferred one isn't configured.
PAYMENT_PROVIDER=squad
# Where the gateway returns the payer after checkout (defaults PUBLIC_BASE_URL).
# PAYMENT_CALLBACK_URL=https://vote.torama.money

# ── Squad (primary NGN rail — GTBank / HabariPay payment links) ────────────
# Each election launch creates a one-off hosted payment link for the exact
# metered amount, then redirects the organiser to pay.squadco.com/<hash>.
# Get keys from dashboard.squadco.com → Profile → API & Webhook.
SQUAD_SECRET_KEY=
# API host.        Sandbox: https://sandbox-api-d.squadco.com  Live: https://api-d.squadco.com
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
# Checkout host.   Sandbox: https://sandbox-pay.squadco.com    Live: https://pay.squadco.com
SQUAD_PAY_BASE_URL=https://sandbox-pay.squadco.com
# Optional static dashboard product link (manual fallback only), e.g.
# SQUAD_PAYMENT_LINK=https://pay.squadco.com/toramavote
#
# On the Squad dashboard (Profile → API & Webhook) set:
#   Webhook URL:  https://vote.torama.money/webhooks/squad-hub   (the shared hub)
#   Redirect URL: https://vote.torama.money/account/pay/callback
#
# ── Squad webhook hub (one account → many apps) ────────────────────────────
# Squad allows only ONE webhook URL per account. This app acts as the hub: it
# verifies the signature once, settles its own payments, and forwards the rest
# to the other apps' /webhooks/squad. List those apps here (JSON). `prefix` is
# optional (comma-separated reference prefixes); omit to broadcast. Leave blank
# if this is the only app on the Squad account. See MULTI-APP-SQUAD.md.
# SQUAD_DOWNSTREAMS=[{"name":"neflo","url":"https://neflo.pay/webhooks/squad","prefix":"nf_,cg_"},{"name":"otuburu","url":"https://otuburu.torama.money/webhooks/squad","prefix":"otu-"}]

# ── Monnify (fallback NGN rail — same sandbox creds proven on otuburu) ─────
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WALLET_ACCOUNT=
# Sandbox: https://sandbox.monnify.com  |  Live: https://api.monnify.com
MONNIFY_BASE_URL=https://sandbox.monnify.com

# ── Per-voter pricing ──────────────────────────────────────────────────────
# Optional JSON override of the rate card. Brackets are [maxVoters, ratePerVoter]
# in MAJOR units; use null for the top (unbounded) bracket. The first 50 voters
# are free. Default (money spec §6) is used when left blank:
#   NGN: 1–50 free, 51–500 ₦120, 501–2,500 ₦90, 2,501–10,000 ₦55,
#        10,001–50,000 ₦35, 50,000+ ₦22
# PRICING_TABLE={"NGN":[[50,0],[500,120],[2500,90],[10000,55],[50000,35],[null,22]],"USD":[[50,0],[500,0.25],[2500,0.18],[10000,0.12],[50000,0.08],[null,0.045]]}

# Election deletion policy.
#   true  = TESTING — admins can delete ANY election (incl. opened/closed).
#   false = PRODUCTION — only unopened 'draft' elections can be deleted; an
#           opened election can only be closed, preserving its record.
# Set this to true while testing, then flip to false before real elections.
ALLOW_ELECTION_DELETE=true

# Platform-admin device audit. When true, open/hybrid (per-device) votes also
# record the client IP + user-agent (visible at /admin → election → Device audit,
# decoupled from ballot choices). OFF by default for privacy. If you enable it,
# disclose IP collection in your privacy notice.
DEVICE_AUDIT_ENABLED=false

# Per-IP rate limits. Defaults suit normal use. Raise temporarily for a load
# test from a single IP (see infra/loadtest/README.md), then set back.
# RATE_LIMIT_GENERAL=120   # requests per minute
# RATE_LIMIT_CODE=20       # voting-code attempts per 10 minutes

# ── Lemon Squeezy monthly subscription — RETIRED ────────────────────────────
# Replaced by Squad per-election payments. Subscriptions are hard-disabled in
# code (services/subscriptions.ts); these keys are inert and kept only so an
# existing .env doesn't break. Leave blank.
SUBSCRIPTIONS_ENABLED=false
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_VARIANT_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# SUBSCRIPTION_PRICE_LABEL=$8 / month
